    <!-- http://www.semanticweb.org/mc/ontologies/2026/3/untitled-ontology-36#Document1 -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/mc/ontologies/2026/3/untitled-ontology-36#Document1">
