    <!-- http://www.semanticweb.org/mc/ontologies/2026/3/untitled-ontology-36#Online_Course2 -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/mc/ontologies/2026/3/untitled-ontology-36#Online_Course2">
        <rdf:type rdf:resource="http://www.semanticweb.org/mc/ontologies/2026/3/untitled-ontology-36#OnlineCourse"/>
        <untitled-ontology-36:gradedBy rdf:resource="http://www.semanticweb.org/mc/ontologies/2026/3/untitled-ontology-36#Tanveer_Khan"/>
